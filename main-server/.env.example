ENVIRONMENT=production
LOG_LEVEL=INFO
BOT_TOKEN=CHANGE_ME
ADMIN_TELEGRAM_IDS=123456789
ADMIN_TOKEN=CHANGE_ME_MINIMUM_32_CHARACTERS
DATABASE_URL=postgresql+asyncpg://subio:CHANGE_ME@postgres:5432/subio
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
POSTGRES_DB=subio
POSTGRES_USER=subio
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
TESTER_BASE_URL=https://tester.example.com
INTERNAL_HMAC_KEY=CHANGE_ME_MINIMUM_32_CHARACTERS
PAYLOAD_ENCRYPTION_KEY=CHANGE_ME_URLSAFE_BASE64_32_BYTES
TESTER_TIMEOUT_SECONDS=10
BREAKER_FAILURE_THRESHOLD=3
BREAKER_RECOVERY_SUCCESSES=2
BREAKER_RESET_SECONDS=45
ARVAN_S3_ENDPOINT=
ARVAN_S3_REGION=ir-thr-at1
ARVAN_S3_BUCKET=
ARVAN_S3_ACCESS_KEY=
ARVAN_S3_SECRET_KEY=
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION=
# خالی بگذار = اسکن همه کانال/گروه/بات‌ها (به‌جز پیوی). اگر مقدار بدهی فقط همان‌ها اسکن می‌شوند.
TELETHON_SOURCE_CHATS=
PUBLIC_BASE_URL=https://subio.vip
# لینک ساب کاربران باید به دامنه ایران اشاره کند (نه سرور خارج)

# Vercel AI Gateway
AI_ENABLED=true
VERCEL_AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
AI_MODEL_SOL=openai/gpt-5.6-sol
AI_MODEL_LUNA=openai/gpt-5.6-luna

# Retest (Iran download budget)
RETEST_HEALTHY_INTERVAL_SECONDS=10
RETEST_HEALTHY_BATCH=8
RETEST_DEAD_INTERVAL_SECONDS=180
RETEST_DEAD_BATCH=5
RETEST_DEMOTE_ON_FIRST_FAIL=true
